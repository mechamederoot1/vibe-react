{
  "name": "vibe-social-network",
  "version": "1.0.0",
  "description": "Vibe Social Network - Modern social media platform",
  "main": "index.js",
  "scripts": {
    "android": "cd mobile && npx react-native run-android",
    "ios": "cd mobile && npx react-native run-ios",
    "start": "cd mobile && npx react-native start",
    "dev:backend": "cd backend && python -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "install:mobile": "cd mobile && npm install",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "install:all": "npm run install:mobile && npm run install:backend",
    "pod-install": "cd mobile/ios && pod install"
  },
  "keywords": ["social network", "react", "fastapi", "vibe"],
  "author": "Vibe Team",
  "license": "ISC"
}